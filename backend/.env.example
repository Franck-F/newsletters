# Database (using psycopg3 driver)
DATABASE_URL=postgresql+psycopg://newsletters:newsletters_dev@localhost:5432/newsletters

# JWT Auth
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Admin seed
ADMIN_EMAIL=admin@newsletter.local
ADMIN_PASSWORD=changeme

# Brevo (ESP)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=newsletter@yourdomain.com
BREVO_SENDER_NAME=My Newsletter

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key

# Gmail API
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json
GMAIL_LABEL=Newsletters

# App
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
